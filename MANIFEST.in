include LICENSE.txt
include README.md
include pyproject.toml

graft xpublish_edr

prune docs
prune tests
prune notebooks
prune *.egg-info

global-exclude *.nc
global-exclude *.py[co]
global-exclude __pycache__

exclude *.yml
exclude *.enc
exclude .gitignore
exclude .isort.cfg
exclude .pre-commit-config.yaml
exclude noxfile.py
